# Copy this file to .env and fill in real values to enable real password-reset
# emails (see systemMailer.ts). Without these set, forgot-password requests
# fall back to a dev-mode response that shows the reset link directly instead
# of emailing it.
#
# SYSTEM_SMTP_EMAIL is the platform's own Gmail address (not a user's).
# SYSTEM_SMTP_APP_PASSWORD is an App Password for that account, generated at
# https://myaccount.google.com/apppasswords - requires 2-Step Verification to
# be turned on. Do NOT use the account's regular login password.
SYSTEM_SMTP_EMAIL=
SYSTEM_SMTP_APP_PASSWORD=

# Used to build the link inside the reset email (e.g. http://localhost:5173/reset-password?token=...).
# Defaults to http://localhost:5173 if unset.
WEB_ORIGIN=http://localhost:5173
